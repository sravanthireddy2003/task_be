# =====================================================
# Environment Variables for Audit System
# =====================================================

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=your_database_name

# Elasticsearch Configuration
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_es_password

# Kibana Configuration
KIBANA_HOST=http://localhost:5601

# Logstash Configuration
LOGSTASH_JDBC_DRIVER_PATH=/path/to/mysql-connector-java-8.0.33.jar
LOGSTASH_POLL_INTERVAL=* * * * *
LOGSTASH_METADATA_PATH=/var/lib/logstash/.logstash_jdbc_last_run_audit_logs

# Redis Configuration (for Bull Queue - optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# Audit System Configuration
AUDIT_ENCRYPTION_KEY=your-32-character-encryption-key-here
AUDIT_CIRCUIT_BREAKER_THRESHOLD=10
AUDIT_BATCH_SIZE=100

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Node Environment
NODE_ENV=production
PORT=3000
